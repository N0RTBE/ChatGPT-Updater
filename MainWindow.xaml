<ui:FluentWindow x:Class="ChatGPTUpdater.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:local="clr-namespace:ChatGPTUpdater"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 Title="{local:Loc WindowTitle}"
                 Width="560" Height="360"
                 MinWidth="560" MinHeight="360"
                 WindowStartupLocation="CenterScreen"
                 ResizeMode="NoResize"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica"
                 WindowCornerPreference="Round"
                 Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                 FontFamily="Segoe UI"
                 UseLayoutRounding="True"
                 SnapsToDevicePixels="True"
                 TextOptions.TextFormattingMode="Display"
                 TextOptions.TextRenderingMode="ClearType"
                 ui:Design.Background="{DynamicResource ApplicationBackgroundBrush}"
                 ui:Design.Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                 Loaded="Window_Loaded"
                 Closing="Window_Closing"
                 mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0"
                     Title="{local:Loc WindowTitle}"
                     Icon="{ui:ImageIcon 'pack://application:,,,/Assets/chatgpt-updater.png'}"
                     CanMaximize="False"
                     ShowMaximize="False"
                     ShowMinimize="False"
                     FlowDirection="LeftToRight" />

        <Grid Grid.Row="1" Margin="32,17,32,28">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="22" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="20" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="52" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Image Grid.Column="0"
                       Width="52" Height="52"
                       Source="Assets/chatgpt-updater.png"
                       Stretch="Uniform"
                       RenderOptions.BitmapScalingMode="HighQuality" />
                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                    <TextBlock Text="{local:Loc WindowTitle}"
                               FontSize="22"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                    <TextBlock Text="{local:Loc Subtitle}"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               FontSize="13"
                               Margin="0,4,0,0" />
                </StackPanel>
            </Grid>

            <ui:Card Grid.Row="2" Padding="18,15">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Separator Grid.Column="1"
                               Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}"
                               Margin="0,1"
                               Opacity="0.55" />
                    <StackPanel Margin="0,0,18,0">
                        <TextBlock Text="{local:Loc Installed}"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   FontSize="12" />
                        <TextBlock x:Name="InstalledVersionText"
                                   Text="—"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Margin="0,4,0,0" />
                    </StackPanel>
                    <StackPanel Grid.Column="2" Margin="18,0,0,0">
                        <TextBlock Text="{local:Loc Available}"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   FontSize="12" />
                        <TextBlock x:Name="AvailableVersionText"
                                   Text="—"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Margin="0,4,0,0" />
                    </StackPanel>
                </Grid>
            </ui:Card>

            <StackPanel Grid.Row="4">
                <TextBlock x:Name="StatusText"
                           Text="{local:Loc Preparing}"
                           FontSize="15"
                           FontWeight="SemiBold"
                           TextWrapping="Wrap" />
                <TextBlock x:Name="DetailText"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           FontSize="12"
                           Margin="0,6,0,0"
                           TextWrapping="Wrap" />
                <ProgressBar x:Name="ProgressBar"
                             Height="4"
                             Margin="0,18,0,0"
                             Minimum="0" Maximum="100"
                             FlowDirection="LeftToRight"
                             IsIndeterminate="True" />
            </StackPanel>

            <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right">
                <ui:Button x:Name="LaunchButton"
                           Appearance="Secondary"
                           Content="{local:Loc LaunchCurrent}"
                           Click="LaunchButton_Click"
                           Visibility="Collapsed"
                           Margin="0,0,8,0" />
                <ui:Button x:Name="RetryButton"
                           Appearance="Primary"
                           Content="{local:Loc Retry}"
                           Click="RetryButton_Click"
                           Visibility="Collapsed" />
                <ui:Button x:Name="InstallButton"
                           Appearance="Primary"
                           Content="{local:Loc InstallChatGPT}"
                           Click="InstallButton_Click"
                           Visibility="Collapsed" />
            </StackPanel>
        </Grid>
    </Grid>
</ui:FluentWindow>
